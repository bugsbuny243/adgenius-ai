generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RunStatus {
  PENDING
  PROCESSING
  WAITING_APPROVAL
  APPROVED
  COMPLETED
  FAILED
}

enum StepStatus {
  SUCCESS
  WARNING
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  passwordHash    String?
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  runs            Run[]
  approvals       Approval[]     @relation("ApprovalActor")
  tasks           Task[]         @relation("TaskAssignee")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Organization {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  users            User[]
  agentTemplates   AgentTemplate[]
  agents           Agent[]
  customers        Customer[]
  workItems        WorkItem[]
  knowledgeSources KnowledgeSource[]
  runs             Run[]
  tasks            Task[]
  notes            Note[]
  timelines        Timeline[]
  approvals        Approval[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model AgentTemplate {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  name            String
  description     String?
  systemPrompt    String
  schemaHint      Json?
  agents          Agent[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
}

model Agent {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id])
  templateId       String?
  template         AgentTemplate?    @relation(fields: [templateId], references: [id])
  name             String
  description      String?
  instructions     String
  isActive         Boolean           @default(true)
  runs             Run[]
  knowledgeSources KnowledgeSource[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([organizationId])
}

model Customer {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id])
  name             String
  email            String?
  phone            String?
  workItems        WorkItem[]
  notes            Note[]
  timelines        Timeline[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId])
}

model WorkItem {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id])
  customerId       String?
  customer         Customer?       @relation(fields: [customerId], references: [id])
  title            String
  status           String          @default("open")
  summary          String?
  sourceRunId      String?
  sourceRun        Run?            @relation("RunWorkItem", fields: [sourceRunId], references: [id])
  tasks            Task[]
  notes            Note[]
  timelines        Timeline[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId])
  @@index([customerId])
}

model KnowledgeSource {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id])
  agentId          String?
  agent            Agent?          @relation(fields: [agentId], references: [id])
  title            String
  mimeType         String
  storageKey       String
  sourceUrl        String?
  extractedText    String?
  createdById      String?
  runs             Run[]
  createdAt        DateTime        @default(now())

  @@index([organizationId])
  @@index([agentId])
}

model Run {
  id                String            @id @default(cuid())
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id])
  agentId           String
  agent             Agent             @relation(fields: [agentId], references: [id])
  startedById       String?
  startedBy         User?             @relation(fields: [startedById], references: [id])
  status            RunStatus         @default(PENDING)
  inputText         String?
  extraction        Json?
  summary           String?
  risks             Json?
  missingFields     Json?
  proposedTasks     Json?
  output            Json?
  knowledgeSourceId String?
  knowledgeSource   KnowledgeSource?  @relation(fields: [knowledgeSourceId], references: [id])
  steps             RunStep[]
  approvals         Approval[]
  workItems         WorkItem[]        @relation("RunWorkItem")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([organizationId])
  @@index([agentId])
}

model RunStep {
  id           String      @id @default(cuid())
  runId        String
  run          Run         @relation(fields: [runId], references: [id])
  stepType     String
  status       StepStatus  @default(SUCCESS)
  title        String
  detail       String?
  payload      Json?
  createdAt    DateTime    @default(now())

  @@index([runId])
}

model Approval {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id])
  runId            String
  run              Run             @relation(fields: [runId], references: [id])
  status           ApprovalStatus  @default(PENDING)
  title            String
  summary          String
  payload          Json
  approvedById     String?
  approvedBy       User?           @relation("ApprovalActor", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  createdAt        DateTime        @default(now())

  @@index([organizationId])
  @@index([runId])
}

model Task {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  title            String
  description      String?
  status           TaskStatus     @default(TODO)
  dueDate          DateTime?
  assigneeId       String?
  assignee         User?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  workItemId       String?
  workItem         WorkItem?      @relation(fields: [workItemId], references: [id])
  sourceRunId      String?
  sourceRun        Run?           @relation(fields: [sourceRunId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId])
  @@index([workItemId])
}

model Note {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  body             String
  customerId       String?
  customer         Customer?      @relation(fields: [customerId], references: [id])
  workItemId       String?
  workItem         WorkItem?      @relation(fields: [workItemId], references: [id])
  sourceRunId      String?
  createdAt        DateTime       @default(now())

  @@index([organizationId])
}

model Timeline {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  title            String
  detail           String?
  happenedAt       DateTime       @default(now())
  customerId       String?
  customer         Customer?      @relation(fields: [customerId], references: [id])
  workItemId       String?
  workItem         WorkItem?      @relation(fields: [workItemId], references: [id])
  sourceRunId      String?
  createdAt        DateTime       @default(now())

  @@index([organizationId])
  @@index([happenedAt])
}
