# Public (build-time + client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server runtime
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_KEY
APP_ORIGIN=http://localhost:3000
AI_PROVIDER=openai
OPENAI_MODEL_PRIMARY=gpt-5.2
OPENAI_MODEL_REASONING=gpt-5.2
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_LIGHT=gpt-5-nano
OPENAI_REASONING_EFFORT=medium

# Google OAuth integration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Game Factory - GitHub Unity repository
GITHUB_UNITY_REPO_OWNER=
GITHUB_UNITY_REPO_NAME=
GITHUB_UNITY_REPO_BRANCH=main
GITHUB_UNITY_REPO_TOKEN=

# Game Factory - Unity Build Automation
UNITY_ORG_ID=
UNITY_PROJECT_ID=
UNITY_BUILD_TARGET_ID=
UNITY_SERVICE_ACCOUNT_KEY_ID=
UNITY_SERVICE_ACCOUNT_SECRET_KEY=

KOSCHEI_CREDENTIALS_ENCRYPTION_KEY=
# Game Factory - Google Play publishing
GOOGLE_PLAY_DEFAULT_TRACK=production

# Super owner override (optional)
